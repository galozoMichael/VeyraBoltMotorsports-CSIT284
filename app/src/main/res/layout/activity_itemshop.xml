<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- ============================================= -->
            <!-- TOP BAR: Logo + Brand Name | Cart Icon        -->
            <!-- ============================================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Logo -->
                <ImageView
                    android:id="@+id/imgShopLogo"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:src="@drawable/veyraboltlogo"
                    android:scaleType="centerInside"
                    android:contentDescription="Veyra Bolt Logo" />

                <!-- Brand name beside logo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Veyra Bolt"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Motorsports"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Cart icon -->
                <ImageView
                    android:id="@+id/imgCart"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:contentDescription="Cart"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Bottom edge line of top bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A2A" />

            <!-- ============================================= -->
            <!-- SECTION: Shop — Featured Banner               -->
            <!-- ============================================= -->
            <TextView
                android:id="@+id/tvShopLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Shop"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Featured Collection Banner -->
            <FrameLayout
                android:id="@+id/bannerFeatured"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/featured_banner_bg"
                android:clickable="true"
                android:focusable="true">

                <!-- Placeholder row of product icons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Product icon 1: Boots -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:contentDescription="Boots"
                            android:scaleType="centerInside" />

                    </FrameLayout>

                    <!-- Product icon 2: Helmet Visor -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_compass"
                            android:contentDescription="Visor"
                            android:scaleType="centerInside" />

                    </FrameLayout>

                    <!-- Product icon 3: Racing Suit -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_manage"
                            android:contentDescription="Racing suit"
                            android:scaleType="centerInside" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Banner label at bottom -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="The Bolt Collection"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Red accent badge -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="6dp"
                    android:background="#E53935" />

            </FrameLayout>

            <!-- ============================================= -->
            <!-- SECTION: Apparel                              -->
            <!-- ============================================= -->
            <TextView
                android:id="@+id/tvApparelLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Apparel"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Horizontal scroll row with nav arrows -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Left arrow -->
                <ImageView
                    android:id="@+id/btnApparelLeft"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="2dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:contentDescription="Scroll left"
                    android:clickable="true"
                    android:focusable="true" />

                <HorizontalScrollView
                    android:id="@+id/scrollApparel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Apparel Item 1 -->
                        <LinearLayout
                            android:id="@+id/itemApparel1"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:contentDescription="T-Shirt 1"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Bolt Tee"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 899"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Apparel Item 2 -->
                        <LinearLayout
                            android:id="@+id/itemApparel2"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:contentDescription="T-Shirt 2"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Race Jersey"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 1,299"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Apparel Item 3 -->
                        <LinearLayout
                            android:id="@+id/itemApparel3"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:contentDescription="T-Shirt 3"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Pit Crew Tee"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 749"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- Right arrow -->
                <ImageView
                    android:id="@+id/btnApparelRight"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="2dp"
                    android:src="@android:drawable/ic_media_next"
                    android:contentDescription="Scroll right"
                    android:clickable="true"
                    android:focusable="true" />

            </FrameLayout>

            <!-- ============================================= -->
            <!-- SECTION: Exclusive Items                      -->
            <!-- ============================================= -->
            <TextView
                android:id="@+id/tvExclusiveLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Exclusive Items"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Horizontal scroll row with nav arrows -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Left arrow -->
                <ImageView
                    android:id="@+id/btnExclusiveLeft"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="2dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:contentDescription="Scroll left"
                    android:clickable="true"
                    android:focusable="true" />

                <HorizontalScrollView
                    android:id="@+id/scrollExclusive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Exclusive Item 1: Helmet -->
                        <LinearLayout
                            android:id="@+id/itemExclusive1"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_compass"
                                android:contentDescription="Helmet"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Bolt Helmet"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 4,999"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Exclusive Item 2: Gloves -->
                        <LinearLayout
                            android:id="@+id/itemExclusive2"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_edit"
                                android:contentDescription="Gloves"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Race Gloves"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 1,899"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Exclusive Item 3: Keychain -->
                        <LinearLayout
                            android:id="@+id/itemExclusive3"
                            android:layout_width="110dp"
                            android:layout_height="140dp"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/item_card_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                android:contentDescription="Keychain"
                                android:scaleType="centerInside" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="VB Keychain"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₱ 349"
                                android:textColor="#E53935"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- Right arrow -->
                <ImageView
                    android:id="@+id/btnExclusiveRight"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="2dp"
                    android:src="@android:drawable/ic_media_next"
                    android:contentDescription="Scroll right"
                    android:clickable="true"
                    android:focusable="true" />

            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav pinned to bottom (same as dashboard) -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#1A1A1A"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
